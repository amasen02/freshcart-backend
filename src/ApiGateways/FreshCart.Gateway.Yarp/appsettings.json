{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "https://freshcart.local/identity",
    "Audience": "https://freshcart.local"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-sign-in": {
        "ClusterId": "identity",
        "RateLimiterPolicy": "auth",
        "Order": 1,
        "Match": { "Path": "/api/auth/sign-in" },
        "Transforms": [ { "PathPattern": "/auth/sign-in" } ]
      },
      "auth-sign-up": {
        "ClusterId": "identity",
        "RateLimiterPolicy": "auth",
        "Order": 1,
        "Match": { "Path": "/api/auth/sign-up" },
        "Transforms": [ { "PathPattern": "/auth/sign-up" } ]
      },
      "auth-refresh": {
        "ClusterId": "identity",
        "RateLimiterPolicy": "auth",
        "Order": 1,
        "Match": { "Path": "/api/auth/refresh" },
        "Transforms": [ { "PathPattern": "/auth/refresh" } ]
      },
      "auth": {
        "ClusterId": "identity",
        "Order": 10,
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/auth/{**catch-all}" } ]
      },
      "account": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/account/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/account/{**catch-all}" } ]
      },
      "catalog-products": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/products/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/products/{**catch-all}" } ]
      },
      "catalog-categories": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/categories/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/categories/{**catch-all}" } ]
      },
      "catalog-brands": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/brands/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/brands/{**catch-all}" } ]
      },
      "basket": {
        "ClusterId": "basket",
        "Match": { "Path": "/api/basket/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/basket/{**catch-all}" } ]
      },
      "ordering": {
        "ClusterId": "ordering",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/orders/{**catch-all}" } ]
      },
      "delivery": {
        "ClusterId": "delivery",
        "Match": { "Path": "/api/delivery/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/delivery/{**catch-all}" } ]
      },
      "reviews": {
        "ClusterId": "reviews",
        "Match": { "Path": "/api/reviews/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/reviews/{**catch-all}" } ]
      },
      "inventory": {
        "ClusterId": "inventory",
        "Match": { "Path": "/api/inventory/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/inventory/{**catch-all}" } ]
      },
      "reporting": {
        "ClusterId": "reporting",
        "Match": { "Path": "/api/reporting/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/{**catch-all}" } ]
      },
      "notifications": {
        "ClusterId": "notification",
        "Match": { "Path": "/api/notifications/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/notifications/{**catch-all}" } ]
      },
      "support": {
        "ClusterId": "customersupport",
        "Match": { "Path": "/api/support/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/support/{**catch-all}" } ]
      },
      "notifications-hub": {
        "ClusterId": "notification",
        "Match": { "Path": "/hubs/notifications" }
      },
      "support-hub": {
        "ClusterId": "customersupport",
        "Match": { "Path": "/hubs/support" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": { "primary": { "Address": "https://localhost:7101" } }
      },
      "catalog": {
        "Destinations": { "primary": { "Address": "https://localhost:7102" } }
      },
      "basket": {
        "Destinations": { "primary": { "Address": "https://localhost:7104" } }
      },
      "ordering": {
        "Destinations": { "primary": { "Address": "https://localhost:7105" } }
      },
      "inventory": {
        "Destinations": { "primary": { "Address": "https://localhost:7106" } }
      },
      "delivery": {
        "Destinations": { "primary": { "Address": "https://localhost:7108" } }
      },
      "notification": {
        "Destinations": { "primary": { "Address": "https://localhost:7109" } }
      },
      "reporting": {
        "Destinations": { "primary": { "Address": "https://localhost:7110" } }
      },
      "customersupport": {
        "Destinations": { "primary": { "Address": "https://localhost:7111" } }
      },
      "reviews": {
        "Destinations": { "primary": { "Address": "https://localhost:7112" } }
      }
    }
  }
}
