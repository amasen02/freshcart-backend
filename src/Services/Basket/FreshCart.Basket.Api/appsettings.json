{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "https://freshcart.local/identity",
    "Audience": "https://freshcart.local"
  },
  "Services": {
    "Catalog": {
      "BaseAddress": "https://localhost:7102"
    },
    "Pricing": {
      "Address": "https://localhost:7103"
    }
  },
  "Outbox": {
    "BatchSize": 100,
    "PollInterval": "00:00:05"
  }
}
